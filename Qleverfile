[data]
NAME             = qlever/ecclesiastical-persons
DESCRIPTION      = Harmonized ecclesiastical-person data (GNDO-centered integration graph)

[index]
# INPUT_FILES is required by the CLI.
INPUT_FILES      = data/harmonized/full.ttl

# Load only the harmonized output graph (no raw source graphs).
MULTI_INPUT_JSON = [
    {"cmd": "cat {}", "format": "ttl", "graph": "https://data.rgonline-integration.de/graph/harmonized", "for-each": "data/harmonized/full.ttl"}
  ]

STXXL_MEMORY     = 4G
ULIMIT           = 1048576

[server]
PORT                        = 7001
ACCESS_TOKEN                = ecclesiastical-persons-token
MEMORY_FOR_QUERIES          = 4G
TIMEOUT                     = 300s
CACHE_MAX_SIZE              = 2G
CACHE_MAX_SIZE_SINGLE_ENTRY = 1G

[runtime]
SYSTEM         = native
INDEX_BINARY   = qlever-index
SERVER_BINARY  = qlever-server

[ui]
UI_PORT        = 7000
