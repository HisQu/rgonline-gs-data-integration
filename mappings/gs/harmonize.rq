PREFIX foaf:   <http://xmlns.com/foaf/0.1/>
PREFIX gsn:    <https://personendatenbank.germania-sacra.de/index/gsn/>
PREFIX gndo:   <https://d-nb.info/standards/elementset/gnd#>
PREFIX org:    <http://www.w3.org/ns/org#>
PREFIX owl:    <http://www.w3.org/2002/07/owl#>
PREFIX part:   <http://purl.org/vocab/participation/schema#>
PREFIX schema: <http://schema.org/>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>

CONSTRUCT {
  ?personOut a gndo:DifferentiatedPerson ;
    gndo:preferredNameForThePerson ?preferredName ;
    gndo:preferredNameEntityForThePerson ?nameEntity ;
    gndo:dateOfBirth ?birthDate ;
    gndo:dateOfDeath ?deathDate ;
    owl:sameAs ?gndURI ;
    gndo:professionOrOccupationAsLiteral ?officeName ;
    gndo:affiliation ?organization ;
    gndo:affiliationAsLiteral ?organizationName ;
    gndo:periodOfActivity ?periodOfActivity .

  ?nameEntity a gndo:NameOfThePerson ;
    gndo:forename ?givenName ;
    gndo:surname ?familyName .

  ?organization a gndo:CorporateBody ;
    gndo:preferredNameForTheCorporateBody ?organizationName ;
    owl:sameAs ?organizationSameAs .
}
WHERE {
  {
    SELECT ?person (MIN(?gsURI) AS ?gsCanonicalURI) WHERE {
      ?person a ?personType .
      VALUES ?personType { foaf:Person "foaf:Person"^^xsd:string }

      OPTIONAL {
        ?person owl:sameAs ?gsURI .
        FILTER(STRSTARTS(STR(?gsURI), STR(gsn:)))
      }
    } GROUP BY ?person
  }
  BIND(COALESCE(?gsCanonicalURI, ?person) AS ?personOut)

  OPTIONAL {
    ?person owl:sameAs ?gndURI .
    FILTER(
      STRSTARTS(STR(?gndURI), "http://d-nb.info/gnd/") ||
      STRSTARTS(STR(?gndURI), "https://d-nb.info/gnd/")
    )
  }

  OPTIONAL { ?person schema:givenName ?givenName }
  OPTIONAL { ?person schema:familyName ?familyName }
  FILTER(BOUND(?givenName) || BOUND(?familyName))

  BIND(
    REPLACE(
      CONCAT(COALESCE(STR(?givenName), ""), " ", COALESCE(STR(?familyName), "")),
      "^\\s+|\\s+$",
      ""
    )
    AS ?preferredName
  )

  BIND(
    IRI(CONCAT("https://data.rgonline-integration.de/id/name/", ENCODE_FOR_URI(STR(?personOut))))
    AS ?nameEntity
  )

  OPTIONAL { ?person schema:birthDate ?birthDate }
  OPTIONAL { ?person schema:deathDate ?deathDate }

  OPTIONAL {
    SELECT ?person
           (SAMPLE(?officeName0) AS ?officeName)
           (SAMPLE(?period0) AS ?periodOfActivity)
    WHERE {
      ?person part:holder_of ?office .
      OPTIONAL { ?office foaf:name ?officeName0 }
      OPTIONAL { ?office part:startDate ?officeStart }
      OPTIONAL { ?office part:endDate   ?officeEnd   }
      BIND(
        IF(BOUND(?officeStart) && BOUND(?officeEnd),
          CONCAT(STR(?officeStart), " - ", STR(?officeEnd)),
          IF(BOUND(?officeStart),
            CONCAT("from ", STR(?officeStart)),
            IF(BOUND(?officeEnd),
              CONCAT("until ", STR(?officeEnd)),
              "")))
        AS ?period0
      )
    }
    GROUP BY ?person
  }

  OPTIONAL {
    SELECT ?person
           (SAMPLE(?organization0) AS ?organization)
           (SAMPLE(?organizationName0) AS ?organizationName)
           (SAMPLE(?organizationSameAs0) AS ?organizationSameAs)
    WHERE {
      ?person org:memberOf ?organization0 .
      OPTIONAL { ?organization0 foaf:name ?organizationName0 }
      OPTIONAL {
        ?organization0 owl:sameAs ?organizationSameAs0 .
        FILTER(STRSTARTS(STR(?organizationSameAs0), "https://klosterdatenbank.germania-sacra.de/"))
      }
    }
    GROUP BY ?person
  }
}