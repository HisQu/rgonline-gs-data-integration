@prefix rgo:    <https://example.org/ontology/> .
@prefix rg:     <https://example.org/ontology/> .
@prefix foaf:   <http://xmlns.com/foaf/0.1/> .
@prefix gndo:   <https://d-nb.info/standards/elementset/gnd#> .
@prefix org:    <http://www.w3.org/ns/org#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <http://schema.org/> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .

<https://rg-gs-gnd-integration.hisqu.de/ontology/>
    a owl:Ontology ;
    rdfs:label "RG/GS harmonization ontology"@en ;
    rdfs:comment "Captures ontology-safe alignments already explicit in GS and RGO harmonize queries. No direct GS-RGO mappings are asserted; GNDO is the bridge."@en ;
    rdfs:comment "Scope: class/property correspondences and source-specific class refinements. Out of scope: string construction, IRI minting, literal normalization, and multi-hop joins requiring SPARQL rules."@en .

#################################################################
# Class alignments
#################################################################

gndo:DifferentiatedPerson
    a owl:Class ;
    rdfs:subClassOf foaf:Person ;
    rdfs:comment "From GS harmonization: GS persons are projected as gndo:DifferentiatedPerson."@en .

#################################################################
# Property alignments GS <-> GNDO
#################################################################

schema:givenName
    a owl:DatatypeProperty ;
    owl:equivalentProperty gndo:forename ;
    rdfs:comment "From GS harmonization: given name contributes to GNDO forename."@en .

schema:familyName
    a owl:DatatypeProperty ;
    owl:equivalentProperty gndo:surname ;
    rdfs:comment "From GS harmonization: family name contributes to GNDO surname."@en .

schema:birthDate
    a owl:DatatypeProperty ;
    owl:equivalentProperty gndo:dateOfBirth ;
    rdfs:comment "From GS harmonization: birth date aligns to GNDO dateOfBirth."@en .

schema:deathDate
    a owl:DatatypeProperty ;
    owl:equivalentProperty gndo:dateOfDeath ;
    rdfs:comment "From GS harmonization: death date aligns to GNDO dateOfDeath."@en .

org:memberOf
    a owl:ObjectProperty ;
    owl:equivalentProperty gndo:affiliation ;
    rdfs:comment "From GS harmonization: membership aligns to GNDO affiliation."@en .

#################################################################
# Property alignments RGO <-> GNDO
#################################################################

rgo:mentionsPerson
    a owl:ObjectProperty ;
    owl:equivalentProperty gndo:relatedPerson ;
    rdfs:comment "From RGO harmonization: mentionsPerson aligns to relatedPerson."@en .

rgo:mentionsPlace
    a owl:ObjectProperty ;
    owl:equivalentProperty gndo:relatedPlaceOrGeographicName ;
    rdfs:comment "From RGO harmonization: mentionsPlace aligns to relatedPlaceOrGeographicName."@en .

rgo:dateValue
    a owl:DatatypeProperty ;
    owl:equivalentProperty gndo:associatedDate ;
    rdfs:comment "From RGO harmonization: dateValue aligns to associatedDate."@en .

gndo:forename a owl:DatatypeProperty .
gndo:surname a owl:DatatypeProperty .
gndo:dateOfBirth a owl:DatatypeProperty .
gndo:dateOfDeath a owl:DatatypeProperty .
gndo:affiliation a owl:ObjectProperty .
gndo:relatedPerson a owl:ObjectProperty .
gndo:relatedPlaceOrGeographicName a owl:ObjectProperty .
gndo:associatedDate a owl:DatatypeProperty .
gndo:affiliationAsLiteral a owl:DatatypeProperty .
gndo:biographicalOrHistoricalInformation a owl:DatatypeProperty .
gndo:gender a owl:ObjectProperty .
gndo:geographicAreaCode a owl:ObjectProperty .
gndo:gndIdentifier a owl:DatatypeProperty .
gndo:gndSubjectCategory a owl:ObjectProperty .
gndo:oldAuthorityNumber a owl:DatatypeProperty .
gndo:periodOfActivity a owl:DatatypeProperty .
gndo:placeOfActivity a owl:ObjectProperty .
gndo:preferredNameEntityForThePerson a owl:ObjectProperty .
gndo:preferredNameForThePerson a owl:AnnotationProperty .
gndo:preferredNameForThePlaceOrGeographicName a owl:AnnotationProperty .
gndo:professionOrOccupation a owl:ObjectProperty .
gndo:professionOrOccupationAsLiteral a owl:DatatypeProperty .
gndo:variantNameEntityForThePerson a owl:ObjectProperty .
gndo:variantNameForThePerson a owl:AnnotationProperty .

#################################################################
# Types
#################################################################

rgo:Lemma a owl:Class .
rgo:Sublemma a owl:Class .

rgo:appearsInLemma a owl:ObjectProperty .
rgo:hasSubEntry a owl:ObjectProperty .
rgo:hasSublemma a owl:ObjectProperty .
rgo:partOfLemma a owl:ObjectProperty .
rgo:headText a owl:DatatypeProperty .
rgo:text a owl:DatatypeProperty .
rgo:sourceId a owl:DatatypeProperty .
rgo:volume a owl:DatatypeProperty .
rgo:fundReferencePart1 a owl:DatatypeProperty .
rgo:fundReferencePart2 a owl:DatatypeProperty .
rgo:fundReferencePart3 a owl:DatatypeProperty .
