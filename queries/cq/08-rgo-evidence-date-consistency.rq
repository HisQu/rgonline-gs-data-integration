# Name: CQ 08: RGO evidence/date consistency
# SortKey: 108
# CQ8
# For persons linked to DNB, do RGO sublemma dates align with person-level
# associatedDate values, and where are dates only available at one level?

PREFIX foaf:   <http://xmlns.com/foaf/0.1/>
PREFIX gnd:    <https://d-nb.info/gnd/>
PREFIX gndo:   <https://d-nb.info/standards/elementset/gnd#>
PREFIX gsn:    <https://personendatenbank.germania-sacra.de/index/gsn/>
PREFIX org:    <http://www.w3.org/ns/org#>
PREFIX owl:    <http://www.w3.org/2002/07/owl#>
PREFIX part:   <http://purl.org/vocab/participation/schema#>
PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
PREFIX rg:     <https://rg-online.dhi-roma.it/rg/>
PREFIX rgo:    <https://rg-online.dhi-roma.it/ontology/>
PREFIX schema: <http://schema.org/>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>

SELECT DISTINCT
  ?dnbPerson
  ?rgoPerson
  ?lemma
  ?sublemma
  ?sublemmaDate
  ?personDate
  ?status
WHERE {
  ?dnbPerson a gndo:DifferentiatedPerson ;
             owl:sameAs ?rgoPerson .
  FILTER(STRSTARTS(STR(?dnbPerson), "https://d-nb.info/gnd/"))
  FILTER(STRSTARTS(STR(?rgoPerson), "https://rg-online.dhi-roma.it/rg/person/"))

  ?rgoPerson rgo:appearsInLemma ?lemma .
  ?lemma (rgo:hasSublemma|rgo:hasSubEntry) ?sublemma .

  OPTIONAL { ?sublemma gndo:associatedDate ?sublemmaDate }
  OPTIONAL { ?rgoPerson gndo:associatedDate ?personDate }

  BIND(
    IF(
      BOUND(?sublemmaDate) && BOUND(?personDate) && STR(?sublemmaDate) = STR(?personDate),
      "exact_match",
      IF(
        BOUND(?sublemmaDate) && BOUND(?personDate),
        "different_values",
        IF(
          BOUND(?sublemmaDate),
          "sublemma_only",
          IF(BOUND(?personDate), "person_only", "no_date")
        )
      )
    ) AS ?status
  )
}
ORDER BY ?dnbPerson ?rgoPerson ?lemma ?sublemma ?status
