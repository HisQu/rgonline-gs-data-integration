# Name: CQ 01: Cross-source identity disagreement
# SortKey: 101
# CQ1
# Which individuals can be reliably identified as the same historical person
# across DNB, Germania Sacra, and RGO, and where do sources disagree?

PREFIX gndo: <https://d-nb.info/standards/elementset/gnd#>
PREFIX owl:  <http://www.w3.org/2002/07/owl#>

SELECT
  ?gndPerson
  (COUNT(DISTINCT ?dnbUri) AS ?dnb_links)
  (COUNT(DISTINCT ?gsUri) AS ?gs_links)
  (COUNT(DISTINCT ?rgoUri) AS ?rgo_links)
  (GROUP_CONCAT(DISTINCT STR(?gsUri);  separator=" | ") AS ?gs_uris)
  (GROUP_CONCAT(DISTINCT STR(?rgoUri); separator=" | ") AS ?rgo_uris)
  (COUNT(DISTINCT ?nameForm) AS ?distinct_name_forms)
  (GROUP_CONCAT(DISTINCT ?nameForm; separator=" || ") AS ?name_forms)
WHERE {
  ?gndPerson a gndo:DifferentiatedPerson .
  FILTER(STRSTARTS(STR(?gndPerson), "https://d-nb.info/gnd/"))

  ?entity (owl:sameAs|^owl:sameAs)* ?gndPerson .
  FILTER(isIRI(?entity))

  OPTIONAL {
    FILTER(STRSTARTS(STR(?entity), "https://d-nb.info/gnd/"))
    BIND(?entity AS ?dnbUri)
  }
  OPTIONAL {
    FILTER(STRSTARTS(STR(?entity), "https://personendatenbank.germania-sacra.de/index/gsn/"))
    BIND(?entity AS ?gsUri)
  }
  OPTIONAL {
    FILTER(STRSTARTS(STR(?entity), "https://rg-online.dhi-roma.it/rg/person/"))
    BIND(?entity AS ?rgoUri)
  }

  OPTIONAL {
    {
      ?entity gndo:preferredNameForThePerson ?nameLit .
    }
    UNION
    {
      ?entity gndo:variantNameForThePerson ?nameLit .
    }
    BIND(STR(?nameLit) AS ?nameForm)
  }
}
GROUP BY ?gndPerson
HAVING (COUNT(DISTINCT ?gsUri) > 0 && COUNT(DISTINCT ?rgoUri) > 0)
ORDER BY DESC(?distinct_name_forms) ?gndPerson
