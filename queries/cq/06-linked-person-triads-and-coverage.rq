# Name: CQ 06: Linked person triads and coverage
# SortKey: 106
# CQ6
# Which linked persons are present in all three sources, and what labels plus
# external links are available per source projection?

PREFIX foaf:   <http://xmlns.com/foaf/0.1/>
PREFIX gnd:    <https://d-nb.info/gnd/>
PREFIX gndo:   <https://d-nb.info/standards/elementset/gnd#>
PREFIX gsn:    <https://personendatenbank.germania-sacra.de/index/gsn/>
PREFIX org:    <http://www.w3.org/ns/org#>
PREFIX owl:    <http://www.w3.org/2002/07/owl#>
PREFIX part:   <http://purl.org/vocab/participation/schema#>
PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
PREFIX rg:     <https://rg-online.dhi-roma.it/rg/>
PREFIX rgo:    <https://rg-online.dhi-roma.it/ontology/>
PREFIX schema: <http://schema.org/>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>

SELECT
  ?dnbPerson
  ?gsPerson
  ?rgoPerson
  ?dnbName
  ?gsName
  ?rgoName
  (COUNT(DISTINCT ?externalLink) AS ?external_links)
WHERE {
  ?dnbPerson owl:sameAs ?gsPerson , ?rgoPerson .

  FILTER(STRSTARTS(STR(?dnbPerson), "https://d-nb.info/gnd/"))
  FILTER(STRSTARTS(STR(?gsPerson), "https://personendatenbank.germania-sacra.de/index/gsn/"))
  FILTER(STRSTARTS(STR(?rgoPerson), "https://rg-online.dhi-roma.it/rg/person/"))

  OPTIONAL { ?dnbPerson gndo:preferredNameForThePerson ?dnbName }
  OPTIONAL { ?gsPerson  gndo:preferredNameForThePerson ?gsName }
  OPTIONAL { ?rgoPerson gndo:preferredNameForThePerson ?rgoName }

  OPTIONAL {
    ?dnbPerson owl:sameAs ?externalLink .
    FILTER(!STRSTARTS(STR(?externalLink), "https://d-nb.info/gnd/"))
    FILTER(!STRSTARTS(STR(?externalLink), "https://personendatenbank.germania-sacra.de/index/gsn/"))
    FILTER(!STRSTARTS(STR(?externalLink), "https://rg-online.dhi-roma.it/rg/person/"))
  }
}
GROUP BY ?dnbPerson ?gsPerson ?rgoPerson ?dnbName ?gsName ?rgoName
ORDER BY ?dnbPerson
