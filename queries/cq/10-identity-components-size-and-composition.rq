# Name: CQ 10: Identity component size and composition
# SortKey: 110
# CQ10
# How large are owl:sameAs identity components around DNB persons, and do they
# include all three source namespaces?

PREFIX foaf:   <http://xmlns.com/foaf/0.1/>
PREFIX gnd:    <https://d-nb.info/gnd/>
PREFIX gndo:   <https://d-nb.info/standards/elementset/gnd#>
PREFIX gsn:    <https://personendatenbank.germania-sacra.de/index/gsn/>
PREFIX org:    <http://www.w3.org/ns/org#>
PREFIX owl:    <http://www.w3.org/2002/07/owl#>
PREFIX part:   <http://purl.org/vocab/participation/schema#>
PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
PREFIX rg:     <https://rg-online.dhi-roma.it/rg/>
PREFIX rgo:    <https://rg-online.dhi-roma.it/ontology/>
PREFIX schema: <http://schema.org/>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>

SELECT
  ?dnbPerson
  (COUNT(DISTINCT ?entity) AS ?component_size)
  (SUM(IF(STRSTARTS(STR(?entity), "https://personendatenbank.germania-sacra.de/index/gsn/"), 1, 0)) AS ?gs_members)
  (SUM(IF(STRSTARTS(STR(?entity), "https://rg-online.dhi-roma.it/rg/person/"), 1, 0)) AS ?rgo_members)
  (SUM(IF(STRSTARTS(STR(?entity), "https://d-nb.info/gnd/"), 1, 0)) AS ?dnb_members)
WHERE {
  ?dnbPerson a gndo:DifferentiatedPerson .
  FILTER(STRSTARTS(STR(?dnbPerson), "https://d-nb.info/gnd/"))

  ?entity (owl:sameAs|^owl:sameAs)* ?dnbPerson .
  FILTER(isIRI(?entity))
}
GROUP BY ?dnbPerson
HAVING (?gs_members > 0 || ?rgo_members > 0)
ORDER BY DESC(?component_size) ?dnbPerson
