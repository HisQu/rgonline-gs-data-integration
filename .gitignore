.idea/*
!.idea/rgonline-gs-data-integration.iml
!.idea/vcs.xml
data/raw/*/*
!data/raw/**/.gitkeep
!data/raw/**/example*
data/harmonized/*
!data/harmonized/.gitkeep
*.pyc
__pycache__/
.venv/
.pytest_cache/
.tdb
secrets.txt

# QLever index files (built locally from Qleverfile)
qlever/*
!qlever/.gitkeep

# Singularity image files
*.sif

# ROBOT jar files and shell script
robot
robot.jar

# Apache Jena Fuseki binaries and runtime files (downloaded locally)
fuseki/*
!fuseki/.gitkeep
run

# QLever UI (cloned separately, not part of this repo)
qlever-ui/

# RDF4J server data and logs (generated at runtime)
rdf4j/data/*
!rdf4j/data/.gitkeep
rdf4j/logs/*
!rdf4j/logs/.gitkeep

# Environment variables
.env
docs/gndo.html

# Samples generated via scripts
example.ttl

# Output files from matching process
data/matching_outputs/*
waterfall.html

# splink temporary files
.tmp
/backup

# Evaluation 
/data/evaluation
