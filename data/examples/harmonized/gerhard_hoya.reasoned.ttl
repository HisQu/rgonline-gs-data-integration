@prefix : <https://rg-gs-gnd-integration.hisqu.de/ontology/> .
@prefix rg: <https://example.org/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rgo: <https://example.org/ontology/> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix gndo: <https://d-nb.info/standards/elementset/gnd#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <http://schema.org/> .
@base <https://rg-gs-gnd-integration.hisqu.de/ontology/> .

<https://rg-gs-gnd-integration.hisqu.de/ontology/> rdf:type owl:Ontology ;
                                                    rdfs:comment "Captures ontology-safe alignments already explicit in GS and RGO harmonize queries. No direct GS-RGO mappings are asserted; GNDO is the bridge."@en ,
                                                                 "Scope: class/property correspondences and source-specific class refinements. Out of scope: string construction, IRI minting, literal normalization, and multi-hop joins requiring SPARQL rules."@en ;
                                                    rdfs:label "RG/GS harmonization ontology"@en .

#################################################################
#    Annotation properties
#################################################################

###  http://xmlns.com/foaf/0.1/page
foaf:page rdf:type owl:AnnotationProperty .


###  https://d-nb.info/standards/elementset/gnd#preferredNameForThePerson
gndo:preferredNameForThePerson rdf:type owl:AnnotationProperty .


###  https://d-nb.info/standards/elementset/gnd#preferredNameForThePlaceOrGeographicName
gndo:preferredNameForThePlaceOrGeographicName rdf:type owl:AnnotationProperty .


###  https://d-nb.info/standards/elementset/gnd#variantNameForThePerson
gndo:variantNameForThePerson rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#gYear
xsd:gYear rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#gYearMonth
xsd:gYearMonth rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://www.w3.org/ns/org#memberOf
org:memberOf rdf:type owl:ObjectProperty ;
             owl:equivalentProperty gndo:affiliation ;
             rdfs:comment "From GS harmonization: membership aligns to GNDO affiliation."@en .


###  https://d-nb.info/standards/elementset/gnd#affiliation
gndo:affiliation rdf:type owl:ObjectProperty .


###  https://d-nb.info/standards/elementset/gnd#gender
gndo:gender rdf:type owl:ObjectProperty .


###  https://d-nb.info/standards/elementset/gnd#geographicAreaCode
gndo:geographicAreaCode rdf:type owl:ObjectProperty .


###  https://d-nb.info/standards/elementset/gnd#gndSubjectCategory
gndo:gndSubjectCategory rdf:type owl:ObjectProperty .


###  https://d-nb.info/standards/elementset/gnd#placeOfActivity
gndo:placeOfActivity rdf:type owl:ObjectProperty .


###  https://d-nb.info/standards/elementset/gnd#preferredNameEntityForThePerson
gndo:preferredNameEntityForThePerson rdf:type owl:ObjectProperty .


###  https://d-nb.info/standards/elementset/gnd#professionOrOccupation
gndo:professionOrOccupation rdf:type owl:ObjectProperty .


###  https://d-nb.info/standards/elementset/gnd#relatedPerson
gndo:relatedPerson rdf:type owl:ObjectProperty ;
                   owl:equivalentProperty rgo:mentionsPerson .


###  https://d-nb.info/standards/elementset/gnd#relatedPlaceOrGeographicName
gndo:relatedPlaceOrGeographicName rdf:type owl:ObjectProperty ;
                                  owl:equivalentProperty rgo:mentionsPlace .


###  https://d-nb.info/standards/elementset/gnd#variantNameEntityForThePerson
gndo:variantNameEntityForThePerson rdf:type owl:ObjectProperty .


###  https://example.org/ontology/appearsInLemma
rgo:appearsInLemma rdf:type owl:ObjectProperty .


###  https://example.org/ontology/hasSubEntry
rgo:hasSubEntry rdf:type owl:ObjectProperty .


###  https://example.org/ontology/hasSublemma
rgo:hasSublemma rdf:type owl:ObjectProperty .


###  https://example.org/ontology/mentionsPerson
rgo:mentionsPerson rdf:type owl:ObjectProperty ;
                   rdfs:comment "From RGO harmonization: mentionsPerson aligns to relatedPerson."@en .


###  https://example.org/ontology/mentionsPlace
rgo:mentionsPlace rdf:type owl:ObjectProperty ;
                  rdfs:comment "From RGO harmonization: mentionsPlace aligns to relatedPlaceOrGeographicName."@en .


###  https://example.org/ontology/partOfLemma
rgo:partOfLemma rdf:type owl:ObjectProperty .


#################################################################
#    Data properties
#################################################################

###  http://schema.org/birthDate
schema:birthDate rdf:type owl:DatatypeProperty ;
                 owl:equivalentProperty gndo:dateOfBirth ;
                 rdfs:comment "From GS harmonization: birth date aligns to GNDO dateOfBirth."@en .


###  http://schema.org/deathDate
schema:deathDate rdf:type owl:DatatypeProperty ;
                 owl:equivalentProperty gndo:dateOfDeath ;
                 rdfs:comment "From GS harmonization: death date aligns to GNDO dateOfDeath."@en .


###  http://schema.org/familyName
schema:familyName rdf:type owl:DatatypeProperty ;
                  owl:equivalentProperty gndo:surname ;
                  rdfs:comment "From GS harmonization: family name contributes to GNDO surname."@en .


###  http://schema.org/givenName
schema:givenName rdf:type owl:DatatypeProperty ;
                 owl:equivalentProperty gndo:forename ;
                 rdfs:comment "From GS harmonization: given name contributes to GNDO forename."@en .


###  https://d-nb.info/standards/elementset/gnd#affiliationAsLiteral
gndo:affiliationAsLiteral rdf:type owl:DatatypeProperty .


###  https://d-nb.info/standards/elementset/gnd#associatedDate
gndo:associatedDate rdf:type owl:DatatypeProperty ;
                    owl:equivalentProperty rgo:dateValue .


###  https://d-nb.info/standards/elementset/gnd#biographicalOrHistoricalInformation
gndo:biographicalOrHistoricalInformation rdf:type owl:DatatypeProperty .


###  https://d-nb.info/standards/elementset/gnd#dateOfBirth
gndo:dateOfBirth rdf:type owl:DatatypeProperty .


###  https://d-nb.info/standards/elementset/gnd#dateOfDeath
gndo:dateOfDeath rdf:type owl:DatatypeProperty .


###  https://d-nb.info/standards/elementset/gnd#forename
gndo:forename rdf:type owl:DatatypeProperty .


###  https://d-nb.info/standards/elementset/gnd#gndIdentifier
gndo:gndIdentifier rdf:type owl:DatatypeProperty .


###  https://d-nb.info/standards/elementset/gnd#oldAuthorityNumber
gndo:oldAuthorityNumber rdf:type owl:DatatypeProperty .


###  https://d-nb.info/standards/elementset/gnd#periodOfActivity
gndo:periodOfActivity rdf:type owl:DatatypeProperty .


###  https://d-nb.info/standards/elementset/gnd#professionOrOccupationAsLiteral
gndo:professionOrOccupationAsLiteral rdf:type owl:DatatypeProperty .


###  https://d-nb.info/standards/elementset/gnd#surname
gndo:surname rdf:type owl:DatatypeProperty .


###  https://example.org/ontology/dateValue
rgo:dateValue rdf:type owl:DatatypeProperty ;
              rdfs:comment "From RGO harmonization: dateValue aligns to associatedDate."@en .


###  https://example.org/ontology/fundReferencePart1
rgo:fundReferencePart1 rdf:type owl:DatatypeProperty .


###  https://example.org/ontology/fundReferencePart2
rgo:fundReferencePart2 rdf:type owl:DatatypeProperty .


###  https://example.org/ontology/fundReferencePart3
rgo:fundReferencePart3 rdf:type owl:DatatypeProperty .


###  https://example.org/ontology/headText
rgo:headText rdf:type owl:DatatypeProperty .


###  https://example.org/ontology/sourceId
rgo:sourceId rdf:type owl:DatatypeProperty .


###  https://example.org/ontology/text
rgo:text rdf:type owl:DatatypeProperty .


###  https://example.org/ontology/volume
rgo:volume rdf:type owl:DatatypeProperty .


#################################################################
#    Classes
#################################################################

###  http://xmlns.com/foaf/0.1/Person
foaf:Person rdf:type owl:Class ;
            rdfs:subClassOf owl:Thing .


###  https://d-nb.info/standards/elementset/gnd#DifferentiatedPerson
gndo:DifferentiatedPerson rdf:type owl:Class ;
                          rdfs:subClassOf foaf:Person ;
                          rdfs:comment "From GS harmonization: GS persons are projected as gndo:DifferentiatedPerson."@en .


###  https://d-nb.info/standards/elementset/gnd#NameOfThePerson
gndo:NameOfThePerson rdf:type owl:Class ;
                     rdfs:subClassOf owl:Thing .


###  https://d-nb.info/standards/elementset/gnd#PlaceOrGeographicName
gndo:PlaceOrGeographicName rdf:type owl:Class ;
                           rdfs:subClassOf owl:Thing .


###  https://example.org/ontology/Lemma
rgo:Lemma rdf:type owl:Class ;
          rdfs:subClassOf owl:Thing .


###  https://example.org/ontology/Sublemma
rgo:Sublemma rdf:type owl:Class ;
             rdfs:subClassOf owl:Thing .


#################################################################
#    Individuals
#################################################################

###  http://viaf.org/viaf/80564658
<http://viaf.org/viaf/80564658> rdf:type owl:NamedIndividual ;
                                owl:sameAs <https://d-nb.info/gnd/136175414> .


