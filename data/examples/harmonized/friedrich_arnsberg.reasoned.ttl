                                              rgo:volume "5" .


###  https://example.org/rg/sublemma/10501952-13
<https://example.org/rg/sublemma/10501952-13> rdf:type owl:NamedIndividual ,
                                                       rgo:Sublemma ;
                                              rgo:partOfLemma <https://example.org/rg/lemma/10501952> ;
