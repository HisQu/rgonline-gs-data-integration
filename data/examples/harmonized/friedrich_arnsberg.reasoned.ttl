                                              rgo:fundReferencePart1 "DC" ;
                                              rgo:fundReferencePart2 "21" ;
                                              rgo:fundReferencePart3 "99rs" ;
                                              rgo:text "R.R., Augustrie [Austrie], Stirie, Karinthie et Carniole dux, com. Tyrolis: decl. obedientiam Eugenio IV. et precipit principibus etc. S.R.I. quatenus huic decl. se conforment in litt. p. Gasparem [Schlick] cancellarium d. regis subscriptis 23. nov. 1446 DC 21 99rs." ;
                                              rgo:volume "5" .


###  https://example.org/rg/sublemma/10501952-14
<https://example.org/rg/sublemma/10501952-14> rdf:type owl:NamedIndividual ,
                                                       rgo:Sublemma ;
                                              rgo:partOfLemma <https://example.org/rg/lemma/10501952> ;
