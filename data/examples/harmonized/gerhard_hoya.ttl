    rgo:volume "5" .

<https://example.org/rg/sublemma/10501952-20> a owl:NamedIndividual,
        rgo:Sublemma ;
    gndo:associatedDate "1447-02-07"^^xsd:date ;
    rgo:fundReferencePart1 "V" ;
    rgo:fundReferencePart2 "365" ;
    rgo:fundReferencePart3 "480rs" ;
    rgo:partOfLemma <https://example.org/rg/lemma/10501952> ;
    rgo:text "et supradicti aep. Magunt. ac marchio Brandenburg., ad quorum instantiam papa [s.d. 7. febr. 47] certas concessiones sup. coll. ad quecumque benef. et eorum possessoribus edidit: decl. suas conc. n. extendi ad Theodericum [de Moers] olim aep. Colon. et Jacobum [de Sierck] olim aep. Trever. hactenus eorum eccll. privatos aut ad eorum provin. et dioc. donec p. papam aliter fuerit ordinatum s.d. [post 7. febr. 1447] V 365 480rs." ;
    rgo:volume "5" .

<https://example.org/rg/sublemma/10501952-21> a owl:NamedIndividual,
        rgo:Sublemma ;
    gndo:associatedDate "1447-02-17"^^xsd:date ;
    rgo:fundReferencePart1 "V" ;
    rgo:fundReferencePart2 "365" ;
    rgo:fundReferencePart3 "479vs" ;
    rgo:partOfLemma <https://example.org/rg/lemma/10501952> ;
    rgo:text "ut supra: decl. suas conc. valere solum pro talibus qui a data ipsarum conc. sibi et suis successoribus obedirent nec antipape et concil. Basil. inantea adhererent 17. febr. 1447 V 365 479vs." ;
    rgo:volume "5" .

