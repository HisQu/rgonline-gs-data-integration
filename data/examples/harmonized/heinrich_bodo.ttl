<https://example.org/rg/sublemma/10501954-5> a owl:NamedIndividual,
        ns2:Sublemma ;
    ns1:associatedDate "1435-12-20"^^xsd:date ;
    ns1:biographicalOrHistoricalInformation "et Sigismundus ac Otto fratres germani Saxonie duces et marchiones Misnen. omnes lantgravii Thuringie, qui occasione heresis Bohemorum gravia dampna sustulerunt: de indulg. pro eccl. Misnen. ab eorum progenitoribus fund. conc. de 7 an. in 2 festivitatibus perpetuo 20. decb. 1435 S 316 262v." ;
    ns1:definition "et Sigismundus ac Otto fratres germani Saxonie duces et marchiones Misnen. omnes lantgravii Thuringie, qui occasione heresis Bohemorum gravia dampna sustulerunt: de indulg. pro eccl. Misnen. ab eorum progenitoribus fund. conc. de 7 an. in 2 festivitatibus perpetuo 20. decb. 1435 S 316 262v." ;
