        ns2:Sublemma ;
    ns1:associatedDate "1433-06-24"^^xsd:date ;
    ns1:biographicalOrHistoricalInformation "et Margareta ux.: alt. port. 21. iun. 33 L 321 281v, lic. elig. confess. 24. iun. 33 L 321 287v, locis interd. 24. iun. 33 L 321 284v, ante diem 24. iun. 1433 L 321 277r." ;
    ns1:definition "et Margareta ux.: alt. port. 21. iun. 33 L 321 281v, lic. elig. confess. 24. iun. 33 L 321 287v, locis interd. 24. iun. 33 L 321 284v, ante diem 24. iun. 1433 L 321 277r." ;
