<https://example.org/rg/sublemma/10501954-2> a owl:NamedIndividual,
        ns2:Sublemma ;
    ns1:associatedDate "1432-04-26"^^xsd:date ;
    ns1:biographicalOrHistoricalInformation "et Sigismundus, duces Saxonie: de lic. elig. confess., alt. port., ante diem, de locis interd. etiam pro ux. et fam. 26. apr. 32 S 276 153vs, de rem. plen. etiam pro ux. 26. apr. 1432 S 276 154r." ;
    ns1:definition "et Sigismundus, duces Saxonie: de lic. elig. confess., alt. port., ante diem, de locis interd. etiam pro ux. et fam. 26. apr. 32 S 276 153vs, de rem. plen. etiam pro ux. 26. apr. 1432 S 276 154r." ;
