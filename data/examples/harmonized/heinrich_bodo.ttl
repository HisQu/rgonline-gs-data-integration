<https://example.org/rg/sublemma/10501954-2> a owl:NamedIndividual,
        rgo:Sublemma ;
    gndo:associatedDate "1432-04-26"^^xsd:date ;
    rgo:fundReferencePart1 "S" ;
    rgo:fundReferencePart2 "276" ;
    rgo:fundReferencePart3 "153vs",
        "154r" ;
    rgo:partOfLemma <https://example.org/rg/lemma/10501954> ;
    rgo:text "et Sigismundus, duces Saxonie: de lic. elig. confess., alt. port., ante diem, de locis interd. etiam pro ux. et fam. 26. apr. 32 S 276 153vs, de rem. plen. etiam pro ux. 26. apr. 1432 S 276 154r." ;
    rgo:volume "5" .

<https://example.org/rg/sublemma/10501954-3> a owl:NamedIndividual,
        rgo:Sublemma ;
    gndo:associatedDate "1433-02-21"^^xsd:date ;
    rgo:fundReferencePart1 "V" ;
    rgo:fundReferencePart2 "370" ;
    rgo:fundReferencePart3 "127vs" ;
    rgo:partOfLemma <https://example.org/rg/lemma/10501954> ;
    rgo:text "dux Saxonie et elector S.R.I., qui nuper oratores ad papam destinavit: breve quo mittit copiam revocationis transl. concil. Basil. ad civit. Bononien. et ei commendat sicut et aliis electoribus protectionem concil. Basilee continuandi hortaturque quod eo quantocitius iret; monet eum ne ante adventum legatorum pape ibi nihil nisi de reductione Bohemorum tractaretur; operetur ipse dux apud alios electores ut Rabanus [de Helmstadt] archiepiscopatum Trever. assequeretur similia brevia ad Conradum [de Daun] aep. Magunt., Theodericum [de Moers] aep. Colon., Fredericum [I.] marchionem Brandenburg., Ludovicum com. Palatinum Reni electores S.R.I. [= RTA X p. 666s n. 391] 21. febr. 1433 V 370 127vs." ;
    rgo:volume "5" .

<https://example.org/rg/sublemma/10501954-4> a owl:NamedIndividual,
        rgo:Sublemma ;
    gndo:associatedDate "1433-06-24"^^xsd:date ;
    rgo:fundReferencePart1 "L" ;
    rgo:fundReferencePart2 "321" ;
    rgo:fundReferencePart3 "277r",
        "281v",
        "284v",
        "287v" ;
    rgo:partOfLemma <https://example.org/rg/lemma/10501954> ;
    rgo:text "et Margareta ux.: alt. port. 21. iun. 33 L 321 281v, lic. elig. confess. 24. iun. 33 L 321 287v, locis interd. 24. iun. 33 L 321 284v, ante diem 24. iun. 1433 L 321 277r." ;
    rgo:volume "5" .

<https://example.org/rg/sublemma/10501954-5> a owl:NamedIndividual,
        rgo:Sublemma ;
    gndo:associatedDate "1435-12-20"^^xsd:date ;
    rgo:fundReferencePart1 "S" ;
    rgo:fundReferencePart2 "316" ;
    rgo:fundReferencePart3 "262v" ;
    rgo:partOfLemma <https://example.org/rg/lemma/10501954> ;
    rgo:text "et Sigismundus ac Otto fratres germani Saxonie duces et marchiones Misnen. omnes lantgravii Thuringie, qui occasione heresis Bohemorum gravia dampna sustulerunt: de indulg. pro eccl. Misnen. ab eorum progenitoribus fund. conc. de 7 an. in 2 festivitatibus perpetuo 20. decb. 1435 S 316 262v." ;
    rgo:volume "5" .

