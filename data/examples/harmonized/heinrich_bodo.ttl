<https://example.org/rg/sublemma/10501954-3> a owl:NamedIndividual,
        ns2:Sublemma ;
    ns1:associatedDate "1433-02-21"^^xsd:date ;
    ns1:biographicalOrHistoricalInformation "dux Saxonie et elector S.R.I., qui nuper oratores ad papam destinavit: breve quo mittit copiam revocationis transl. concil. Basil. ad civit. Bononien. et ei commendat sicut et aliis electoribus protectionem concil. Basilee continuandi hortaturque quod eo quantocitius iret; monet eum ne ante adventum legatorum pape ibi nihil nisi de reductione Bohemorum tractaretur; operetur ipse dux apud alios electores ut Rabanus [de Helmstadt] archiepiscopatum Trever. assequeretur similia brevia ad Conradum [de Daun] aep. Magunt., Theodericum [de Moers] aep. Colon., Fredericum [I.] marchionem Brandenburg., Ludovicum com. Palatinum Reni electores S.R.I. [= RTA X p. 666s n. 391] 21. febr. 1433 V 370 127vs." ;
    ns1:definition "dux Saxonie et elector S.R.I., qui nuper oratores ad papam destinavit: breve quo mittit copiam revocationis transl. concil. Basil. ad civit. Bononien. et ei commendat sicut et aliis electoribus protectionem concil. Basilee continuandi hortaturque quod eo quantocitius iret; monet eum ne ante adventum legatorum pape ibi nihil nisi de reductione Bohemorum tractaretur; operetur ipse dux apud alios electores ut Rabanus [de Helmstadt] archiepiscopatum Trever. assequeretur similia brevia ad Conradum [de Daun] aep. Magunt., Theodericum [de Moers] aep. Colon., Fredericum [I.] marchionem Brandenburg., Ludovicum com. Palatinum Reni electores S.R.I. [= RTA X p. 666s n. 391] 21. febr. 1433 V 370 127vs." ;
    ns2:fundReferencePart1 "V" ;
    ns2:fundReferencePart2 "370" ;
    ns2:fundReferencePart3 "127vs" ;
    ns2:partOfLemma <https://example.org/rg/lemma/10501954> ;
    ns2:volume "5" .

