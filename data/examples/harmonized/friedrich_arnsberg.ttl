<https://example.org/rg/sublemma/10501952-18> a owl:NamedIndividual,
        ns2:Sublemma ;
    ns1:associatedDate "1447-02-05"^^xsd:date ;
    ns1:biographicalOrHistoricalInformation "et supradicti aep. et marchio: decl. se contentum esse certis decretis Basilee editis et p. quond. Albertum R.R. acceptatis; insuper ratificat omnia que vig. huius acceptationis adhuc gesta sint; decernitque quod legatum ad partes Germanie transmitteret c. pot. ad concordandum c. ipso rege aliisque principibus sup. observantia et modificatione supradictorum; promittit, si infra 6 menses ei obedientiam declararent, se toleraturum quod principes d. decretis uterentur donec aut p. d. legatum concordatum factum aut p. suprad. concil. gener. aliter fuerit ordinatum [= Mercati, Raccolta p. 169s] 5. febr. 1447 V 365 463rs." ;
    ns1:definition "et supradicti aep. et marchio: decl. se contentum esse certis decretis Basilee editis et p. quond. Albertum R.R. acceptatis; insuper ratificat omnia que vig. huius acceptationis adhuc gesta sint; decernitque quod legatum ad partes Germanie transmitteret c. pot. ad concordandum c. ipso rege aliisque principibus sup. observantia et modificatione supradictorum; promittit, si infra 6 menses ei obedientiam declararent, se toleraturum quod principes d. decretis uterentur donec aut p. d. legatum concordatum factum aut p. suprad. concil. gener. aliter fuerit ordinatum [= Mercati, Raccolta p. 169s] 5. febr. 1447 V 365 463rs." ;
