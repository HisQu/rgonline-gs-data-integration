    ns2:volume "5" .

<https://example.org/rg/lemma/10502337> a owl:NamedIndividual,
        ns2:Lemma ;
    ns1:preferredNameForTheSubjectHeading "Gobelinus van zue Campe civ. Colon., qui neptem quond. Alheidis Johannis de Derne al. d. Vingherlinc in ux. habet, proponens amplius dotare alt. s. Crucis in par. eccl. s. Pauli Colon.; quod alt. olim d. quond. Alheidis fund. et dotavit redditibus 32 fl. Ren. ex 2 domibus Vrijburgh et zonne Sternen nunc. in foro op. Bunnen. Colon. dioc. prout apparet in litt. theutonicali sigillo scabinorum d. op. sigillata, accedente ad id consensu Mathie de Lapide rect. par. eccl. sub certis conditionibus reservato d. Alheidi iur. patron., quod deinde ad provisores d. eccl. devolveretur prout apparet in litt. Cristiani de Erpel prep. eccl. b. Marie ad Gradus Colon. commissarii Theoderici [de Moers] aep. Colon.; que Alheidis present. quond. Hermannum Rollandi Clappergas consang. eius, qui d. alt. obtin." ;
    ns1:relatedPerson <https://example.org/rg/person/10500057>,
        <https://example.org/rg/person/10502958>,
        <https://example.org/rg/person/10505175>,
        <https://example.org/rg/person/10507466>,
        <https://example.org/rg/person/10513825>,
        <https://example.org/rg/person/10517697> ;
    ns1:relatedPlaceOrGeographicName <https://example.org/rg/ort/10502217>,
        <https://example.org/rg/ort/10503963>,
        <https://example.org/rg/ort/10503994>,
        <https://example.org/rg/ort/10504059> ;
    ns2:hasSublemma <https://example.org/rg/sublemma/10502337-1> ;
    ns2:sourceId "10502337" ;
    ns2:volume "5" .

