<https://example.org/rg/sublemma/10501952-16> a owl:NamedIndividual,
        ns2:Sublemma ;
    ns1:associatedDate "1447-02-05"^^xsd:date ;
    ns1:biographicalOrHistoricalInformation "et Theodericus [de Erpach] aep. Magunt. et Fredericus [II.] marchio Brandenburg., electores S.R.I., qui p. suos oratores sepe a papa petiverunt, ut novum quoddam concil. gener. in Alamania in uno de 5 locis, videlicet Constantia, Argentina, Maguntia, Wormatia et Treveri, convocet: eis promittit ut, si omn. infra 10 menses in uno ex d. 5 locis consentiant, eo gener. concil. infra 18 menses initiandum convocaret [= Mercati, Raccolta p. 168s] 5. febr. 1447 V 365 462rs." ;
    ns1:definition "et Theodericus [de Erpach] aep. Magunt. et Fredericus [II.] marchio Brandenburg., electores S.R.I., qui p. suos oratores sepe a papa petiverunt, ut novum quoddam concil. gener. in Alamania in uno de 5 locis, videlicet Constantia, Argentina, Maguntia, Wormatia et Treveri, convocet: eis promittit ut, si omn. infra 10 menses in uno ex d. 5 locis consentiant, eo gener. concil. infra 18 menses initiandum convocaret [= Mercati, Raccolta p. 168s] 5. febr. 1447 V 365 462rs." ;
