<https://example.org/rg/sublemma/10501952-17> a owl:NamedIndividual,
        ns2:Sublemma ;
    ns1:associatedDate "1447-02-05"^^xsd:date ;
    ns1:biographicalOrHistoricalInformation "et supradicti aliique prelati et principes nationis Germanice pro Jacobo [de Sierck] olim aep. Trever. et Theoderico [de Moers] olim aep. Colon. etiam electoribus S.R.I. et eorum eccll. intervenientes: eis promittit ut quamprimum d. Jacobus et Theodericus Eugenium IV. agnoverint eos in pristinum statum restitueret [= Mercati, Raccolta p. 170s] 5. febr. 1447 V 365 462vs, fragm. s.d. V 365 467r." ;
