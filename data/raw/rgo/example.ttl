<https://example.org/rg/sublemma/10500492-4>
        a                      rgo:SubEntry ;
        rgo:dateValue           "1445-07-14"^^xsd:date ;
        rgo:fundReferencePart1  "S" , "L" ;
        rgo:fundReferencePart2  "422" , "406" ;
        rgo:fundReferencePart3  "230r" , "116vss" ;
        rgo:partOfLemma         <https://example.org/rg/lemma/10500492> ;
        rgo:text                "qui nolens accedere protestationem neutralitatem nunc. principum nationis Germanie clerum et alios probos viros dominiorum suorum in provin. Colon. existentium convocavit, declarans se c. suis subditis Eugenio IV. adherere velle, et precepit eis sub gravibus penis idem facere; sed Theodericus [de Moers] aep. Colon. et eius officc. iurisdictionem eccles. habentes Johannem Vige rect. par. eccl. op. Novimagen. Colon. dioc. et eius fratres et amicos et alia op., villas et loca d. dominiorum et illorum incolas c. censuris eccles. et penis corporalibus et mulctis gravissimis defatigaverunt, contra quas ipse dux eos protegere nequit: de totali exempt. dominiorum suorum in provin. Colon. existentium et eorum subiectione ep. et eccl. Traiect., in cuius dioc. maior pars suorum dominiorum existit conc. durante neutralitate et subiciatur ep. Traiect. c. absol. a censuris p. d. aep. promulgatis 14. iul. 1445 S 406 116vss, L 422 230r–232v." ;
        rgo:volume              "5" .

