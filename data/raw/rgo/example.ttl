<https://example.org/rg/sublemma/10500672-1>
        a                      rgo:SubEntry ;
        rgo:dateValue           "1431-12-18"^^xsd:date ;
        rgo:fundReferencePart1  "V" ;
        rgo:fundReferencePart2  "371" ;
        rgo:fundReferencePart3  "141v" ;
        rgo:partOfLemma         <https://example.org/rg/lemma/10500672> ;
        rgo:text                "1 concil. ecomenicum in civit. B.: congregatum, quo primum Julianus [de Cesarinis] s. Angeli diac. card. legatus Martini V. se transtulit et nulla ibi adhuc congregatione inventa versus Bohemiam perrexit; deinde premissis Johanne Palomar aud. et Johanne de Ragusio mag. in theol. procur. o. pred. d. card. J. ad civit. B. reversus adhuc paucos prelatos invenit et Johannem Pulchri Patris [Beaupère] mag. in theol. can. eccl. Bisuntin. ad papam misit informaturum eum de statu eccl. in Bohemia: transfert concil. ad civit. Bononien. quia Hussite usque ad partes Basilee propinquas adventi sint, etiam propter hiemem et differentias inter Johannem [d. Bonum] ducem Burgundie et Fredericum ducem Austrie aditus ad d. civit. B. incertus sit, demum quia nuntii Grecorum civit. Italie proposuerint [= Mon. Conc. gen. sec. 15, Concil. Basil. 2, 72–75] 18. decb. 1431 V 371 141v–143v." ;
        rgo:volume              "5" .

<https://example.org/rg/sublemma/10500672-91>
        a               rgo:SubEntry ;
        rgo:dateValue    "1437-07-03"^^xsd:date ;
        rgo:partOfLemma  <https://example.org/rg/lemma/10500672> ;
        rgo:text         "cursores ad concil.: Conzo cursor qui apportavit litteras de B.: assign. 28 fl. p.m. Thome de Spinellis 3. iul. 1437 M 828 130v." ;
        rgo:volume       "5" .

<https://example.org/rg/sublemma/10500672-13>
        a                      rgo:SubEntry ;
        rgo:dateValue           "1437-05-30"^^xsd:date ;
        rgo:fundReferencePart1  "V" ;
        rgo:fundReferencePart2  "366" ;
        rgo:fundReferencePart3  "212r" ;
        rgo:partOfLemma         <https://example.org/rg/lemma/10500672> ;
        rgo:text                "concil. ecomenicum in civit. B.: concil. gener. quod ad hortationem N[icolai de Albergatis] tit. s. Crucis card. et J[ohannis Cervantes] tit. s. Petri ad vincula card. legatorum pape pro eius transl. ad alium locum ambassiatoribus et deputatis Grecorum et aliarum eccl. orientalium aptiorem decrevit ut locum concil. aut Florentiam aut Utinum in provin. Foroiulii inserto protocollo sessionis d. concil. s.d. 15. sept. [36] in qua lecta fuit protestatio ambassiatoris Grecorum contra civit. Avenionensem coram presidentibus Juliano [de Cesarinis] et aliis, inter quos nominantur Ludovicus [de Tek] patriarcha Aquileg. et Johannes [Schele] ep. Lubic.; inter testes nominatur Johannes de Bachestein archidiac. Zagrab. decr. doct.: consentit d. decreto 30. mai. 1437 V 366 212r–214r." ;
        rgo:volume              "5" .

