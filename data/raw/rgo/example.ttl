<https://example.org/rg/sublemma/10501017-20>
        a                      rgo:SubEntry ;
        rgo:dateValue           "1432-03-28"^^xsd:date ;
        rgo:fundReferencePart1  "S" , "L" ;
        rgo:fundReferencePart2  "276" , "317" ;
        rgo:fundReferencePart3  "171vss" , "34rs" ;
        rgo:partOfLemma         <https://example.org/rg/lemma/10501017> ;
        rgo:text                "dec. et capit. eccl. s. Severini C., qui ius present. ad par. eccl. in Overbach Colon. dioc. <que ultra amnem Reni circa silvas ubi guerrarum strepitus plerumque vigere consueverunt sita est> ex donatione recenti quond. Hermanni ipsius eccl. s. S. prep. receperant sub conditione quod unus ex d. capit. ibi curam gereret et aep. de cathedratico et archidiac. et dec. minori eccl. Colon. de exhibitione sua responderet et min. decimam exceptis decimis in Heumere Heumericii <d. dioc.> de quib. 2 m. arg. dumtaxat recip. et reliquos fruct. fr. d. eccl. pro memoria d. prep. cederet, <que donatio a quond. Theoderico aep. Colon. et quond. Engelberto prep. maior. eccl. Colon. et archidiac. d. loci conf. est> postea a Juliano [de Cesarinis] card. s. Angeli legato in partibus Germanie taliter modificata, quod et alteri persone d. prepos. committ. val. quod a Christiano Erpel prep. eccl. b. Marie ad Gradus Colon. iudice delegato d. card. conf. est: de conf. donationis et lic. d. legati 28. mart. 1432 S 276 34rs, L 317 171vss." ;
        rgo:volume              "5" .

