        rgo:sourceId        "10508578" ;
        rgo:volume          "5" .

<https://example.org/rg/sublemma/10506741-4>
        a                      rgo:SubEntry ;
        rgo:dateValue           "1432-07-02"^^xsd:date ;
        rgo:fundReferencePart1  "S" , "L" ;
        rgo:fundReferencePart2  "278" , "312" ;
        rgo:fundReferencePart3  "165r" , "206vss" ;
        rgo:partOfLemma         <https://example.org/rg/lemma/10506741> ;
        rgo:text                "cler. Colon. dioc., <rect. alterius beneff. ad alt. ss. Catharine et Barbare situm sub turri eccl. ss. Petri et Andree Paderburn.>, unac. Hermanno <Nyem> dec., Conrado Decker can. d. eccl. ss. Petri et Andree Paderburn. et Hermanno Cremer presb. vic. in d. eccl. executor testamenti quond. Henrici Holtsmync Holtsmyne dec. d. eccl.; qui executores et quond. Henricus Mordax rect. d. alt. in eo benef. iuxta voluntatem testatoris fundaverunt, 20 fl. Ren. red. annualium in dotem ipsius collatis, sub conditione, quod quousque d. H. M. viveret, 2 distincta beneff. in d. alt. remanerent, que vac. p. cessionem alterius vic. unum benef. fierent, p. superstitem rect. tenendum qui astrictus sit ad 4 missas singulis hebdomadis; quod p. litt. autenticas capit. d. eccl. ac d. H. M. ratificatum et p. <Gerhardum> offic. eccl. Paderburn. <et vic. gener. Theoderici [de Moers] aep. Colon. eccl. Paderburn. admin. p. sed. ap. deput. auct. ordin.> conf. est; H. M. mortuo ipse M. B. d. benef. primum pacifice assec. est, Sandero Saudeto de Horne cler. Paderburn. dioc., cui de altera vicar. quam d. quond. H. M. obtinebat auct. ap. prov. fuit, resignante: de adm. resign. d. S. de H. et de conf. d. ordinationis, ut ambo beneff. unum tantum censeri valeant 2. iul. 1432 S 278 206vss, exec.: abb. mon. ss. Petri et Pauli Padeburn. L 312 165r–166v." ;
        rgo:volume              "5" .

<https://example.org/rg/sublemma/10506232-4>
        a                      rgo:SubEntry ;
        rgo:dateValue           "1432-05-06"^^xsd:date ;
        rgo:fundReferencePart1  "S" ;
        rgo:fundReferencePart2  "281" ;
        rgo:fundReferencePart3  "176vs" ;
        rgo:partOfLemma         <https://example.org/rg/lemma/10506232> ;
        rgo:text                "maior. eccl. ss. Marie et Lamberti: Johannes [de Heinsberg] ep. Leod. et canonici maior. eccl. et aliarum eccll. civit. L. necnon villicus, scabini, magistricivium, gubernatores et iurati ministeriorum civit. L. qui antequam ad eorum off. vel canonn. admittebantur, iuraverunt ut est solitum quod de eorum consensu firmitas aliqua vel gabella sup. res venales in d. civit. poni n. deberet: de conc. quod p. 3 an. sup. d. res venales firmitatem imponere et levare valeant et de relaxatione a d. iuram., quia occasione concordie inter eos et patriam L. et Philippum ducem Burgundie et Brabantie inite magnis pecunie summis indigent conc. ad 2 an. 6. mai. 1432 S 281 176vs." ;
        rgo:volume              "5" .

