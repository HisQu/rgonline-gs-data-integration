<https://example.org/rg/sublemma/10509027-1>
        a                      rgo:SubEntry ;
        rgo:dateValue           "1437-01-11"^^xsd:date ;
        rgo:fundReferencePart1  "S" ;
        rgo:fundReferencePart2  "331" ;
        rgo:fundReferencePart3  "29v" ;
        rgo:partOfLemma         <https://example.org/rg/lemma/10509027> ;
        rgo:text                "sorores conv. Vallisiosephat tertie regule o. s. Francisci de penitentia in op. W., a Wilhelmo dom. loci in W. et Hermanna de Batenborch eius ux. fundati qui fundatores fundum c. domo inter cimit. capel. s. Michaelis et murum d. op. donaverunt satisfactione prius facta rectori d. capel., cui olim a predecessoribus d. fundatorum tales donati fuerunt, et aliam domum pro perfectione et confirmatione d. conv., de consensu Reymari pastoris in Gheysteren in cuius paroch. d. op. W. consistit et vic. d. capel.; quam fundationem Henricus de Erpell prep. eccl. s. Severini Colon. tunc vic. gener. in spirit. Theoderici [de Moers] aep. Colon. nomine d. aep. approbavit et d. conv. erexit et sub protectione eccl. Colon. suscepit, decernens quod prima vice prior can. reg. in Gaessdonck et deinde alius prior d. ord. d. dioc. p. ipsas sorores eligendus visitator sit, approbans deinde coll. alt. et investitionem, quas d. fundatores ad d. mon. transtulerunt, concedens eis confess. c. certis facult. et ius sepeliendi sorores in cimit. d. capel. s. M. annexo: de conf. fundationis et erectionis d. mon. et privil. conc. de conf. 11. ian. 1437 S 331 29v–31r." ;
        rgo:volume              "5" .

