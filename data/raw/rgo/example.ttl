<https://example.org/rg/sublemma/10500672-102>
        a                      rgo:SubEntry ;
        rgo:dateValue           "1437-07-04"^^xsd:date ;
        rgo:fundReferencePart1  "S" ;
        rgo:fundReferencePart2  "338" ;
        rgo:fundReferencePart3  "10vss" ;
        rgo:partOfLemma         <https://example.org/rg/lemma/10500672> ;
        rgo:text                "magistricivium, consilium et communitas civit. Basil., de quorum fide sibi ex relatione cuiusdam aep. et sociorum nuntiorum pape ex d. civit. certior facta est: communitas et cives B.: de cass. cuiusdam conf. priorisse et conv. mon. in Clingental in Minori Basilea o. s. Aug. Constant. dioc. conc. in qua referebatur quod ipsae olim in loco Zu den Husern Basil. dioc. existentes se transtulerunt ad d. locum Cl. et regimini fr. o. pred. se subiecerunt, sed propter negligentiam d. fr. se postea ep. Constant. subiecerunt sub cuius tuitione iam 2 an. degunt quia tacuerint ipsae priorissa et moniales, quod tunc gener. mag. d. ord. domum fr. d. ord. e.m. Basil. ad observ. reg. reducere cepisset in qua iam ab aliquibus an. degunt et ipsae moniales de Cl. evidenter reformationem evitare voluerint p. d. fr. sub reg. observ. iam aliud mon. b. Marie Magdalene ad Lapides e.m. d. civit. B. laudabiliter ref. sit et de declaratione quod d. mon. in Cl. ab omn. iurisdictione exemptum et regimini d. fr. o. pred. sub reg. observ. subiectum sit 4. iul. 1437 S 338 10vss." ;
        rgo:volume              "5" .

