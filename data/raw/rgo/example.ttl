<https://example.org/rg/sublemma/10502581-6>
        a                      rgo:SubEntry ;
        rgo:dateValue           "1432-10-07"^^xsd:date ;
        rgo:fundReferencePart1  "S" ;
        rgo:fundReferencePart2  "280" ;
        rgo:fundReferencePart3  "184vss" ;
        rgo:partOfLemma         <https://example.org/rg/lemma/10502581> ;
        rgo:text                "qui olim et quond. Johannes Rosmyt presb. Monast. dioc. c. nonnullis clericis vitam communem degere desideraverunt de consensu Theoderici [de Moers] aep. Colon. qui certa statut. approbavit, cui communitati quond. Henricus Hunolt al. de Curbach presb. Paderburn. quandam domum donavit dictam Zo Tzo Widenbach Wydenbach c. vinea contigua et quibusdam bonis infra lim. paroch. s. Mauritii Colon. consistentem: de conf. donationis et de approb. communitatis eorum et de lic. erig. capel. domesticam in d. domo sine campanili et de lic. div. off. celebr. etiam temp. interd. et de lic. elig. confess. ex eorum numero c. lic. sacramenta eis ministrandi; n.o. iure parochie conc. de omn. c. consensu rect. 7. oct. 1432 S 280 184vss." ;
        rgo:volume              "5" .

