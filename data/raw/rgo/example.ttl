<https://example.org/rg/lemma/10508968>
        a                  rgo:RegestEntry ;
        rgo:hasSubEntry     <https://example.org/rg/sublemma/10508968-3> , <https://example.org/rg/sublemma/10508968-2> , <https://example.org/rg/sublemma/10508968-4> , <https://example.org/rg/sublemma/10508968-1> ;
        rgo:headText        "Ulricus de Manderscheyt olim pretensus el. Trever., de eccl. Trever. c. Rabano [de Helmstadt] aep. Trever. contendens; ut finem facerent gravibus damnis eccl. Trever. Theodericus [de Moers] aep. Colon. ac Theodericus [de Erpach] el. Magunt. necnon Fredericus [de Domneck] ep. Wormat. quandam conventionem fecerant, ut novem compromissores alterum contendentium aut alium tertium alias episcopum pronuntiarent aep. Trever., alteri pens. etiam c. habitatione decenti sup. fruct. mense aepisc. Trever. providentes; quali compromisso papa dudum consenserat instituens sicut compromissores d. Theodericum el. Magunt. et Fredericum ep. Wormat., diversis disp., absol., rehab. et mandatis necessariis concessis a sent. latis in concilio Basil., a vinculo quo d. Rabanus eccl. Trever. et alius ep. sue eccl. tenebatur, pens. de bonis aepisc. trahenda, mandatum novo aep. obediendi; ipse U. p. ep. Wormat. a concil. Basil. et a Rabano potestatem habentem a sent. latis contra eum absolveretur, quamprimum compromisso consentiret; qui compromissores Rabanum [de Helmstadt] aep. Trever. nominaverunt ipsi Ulrico pens. 2000 fl. Ren. ac castrum Stolzenfels ad eccl. Trever. pertinens pro habitatione ad vitam assignantes" ;
        rgo:mentionsPerson  <https://example.org/rg/person/10517770> , <https://example.org/rg/person/10518242> , <https://example.org/rg/person/10516275> , <https://example.org/rg/person/10517697> , <https://example.org/rg/person/10504258> ;
        rgo:mentionsPlace   <https://example.org/rg/ort/10518427> , <https://example.org/rg/ort/10519938> , <https://example.org/rg/ort/10520247> , <https://example.org/rg/ort/10519946> , <https://example.org/rg/ort/10522228> ;
        rgo:sourceId        "10508968" ;
        rgo:volume          "5" .

