<https://example.org/rg/sublemma/10501952-19>
        a                      rgo:SubEntry ;
        rgo:dateValue           "1447-02-07"^^xsd:date ;
        rgo:fundReferencePart1  "V" ;
        rgo:fundReferencePart2  "365" ;
        rgo:fundReferencePart3  "463v" ;
        rgo:partOfLemma         <https://example.org/rg/lemma/10501952> ;
        rgo:text                "supradicti ac Fredericus [de Emmerberg] aep. Salzeburg. et Gerhardus [de Hoya] aep. Bremen. qui p. oratores obedientiam prestiterunt: omn. collationes ad quevis eccles. benef. temp. neutralitatis s.d. 17. mart. 38 computato factas ratificat et conf. etiam coll. illorum qui Basilee post transl. concil. remanserant, lites desup. extinguens preter lites sup. eccl. Frising. ac eccl. Osil., cassatque omn. sententias que contra adherentes d. neutralitati et eorum subditos fulminate fuerint si infra 6 menses ei obedientiam declararent; quascumque obligationes sup. ann. et min. servitiis ceterisque iur. S.R.E. debitis ad diem remitt.; dispensationes, indulta et novas prov. a d. concil. Basil. conc. confirmat et lites desup. pendentes cass.; omn. adherentes d. concil. etiam off. ibi exercentes absol. et rehab.; sup. eccl. Trever. ac eccl. Colon. ad supplic. R.R. et suprad. aep. Magunt. et marchionis Brandenburg. separatim ordinavit; que omnia c. assensu cardinalium se firmiter tenere promittit [= Mercati, Raccolta p. 171–172] 7. febr. 1447 V 365 463v–466r." ;
        rgo:volume              "5" .

