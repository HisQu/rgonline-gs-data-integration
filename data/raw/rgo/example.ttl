<https://example.org/rg/sublemma/10508905-3>
        a                      rgo:SubEntry ;
        rgo:dateValue           "1432-06"^^xsd:gYearMonth ;
        rgo:fundReferencePart1  "Arm. XXXIX" ;
        rgo:fundReferencePart2  "6" ;
        rgo:fundReferencePart3  "189v" ;
        rgo:partOfLemma         <https://example.org/rg/lemma/10508905> ;
        rgo:text                "nob. viri comites, barones, milites ceterique militares vasalli sub dominio temporali eccl. T. constituti, quos certiores fecit primo, quib. de causis Martinus V. Rabanum [de Helmstadt] ep. Spiren. ad eccl. T. transtulisset, et quod deinde plures ex gremio capit. T. Jacobum de Sirck Sintck tunc scolast. d. eccl. elegissent quem ad papam misissent, unde reversus est c. nuntio translationis; tamen ad instigationem quorundam tyrannorum et precipue Ruberti com. de Virneberg et complicum Ulricum de Manderscheit Mandelscheit tunc dec. eccl. Colon. nominavissent, in el. assumpsissent et ei fidelitatem et homagium prestitissent; Martinus V. tunc Franchiscum de Folenghis de Mantua decr. doct. nuntium ad hoc specialem ad partes T. misisset c. litt. pape, quib. et Ulricum de Manderscheit et Rubertum de Virneberg adhortaretur, ut ab occupatione eccl. T. desisterent et dec. etc. rebelles, ut cessarent a suo schismate; sed hii latorem d. litt. p. aque submersionem occidissent, quare he et alie litt. presentate n. fuerint: dec. et capit. eccl. T.: p. breve hortatur eos ut pens. annuam 2000 fl. adc., quos Martinus V. occasione transl. Rabani [de Helmstadt] aep. Trever. reservavit Ja[cobo de] Sirck prep. eccl. Herbip. de bar. gen. not. et cubic. pape alias a maiori parte capit. ad eccl. T. electo ex fruct. d. eccl. et mensa aepisc. persolvant et quod litt. desup. et Martini V. et Eugenii IV. eidem J. restituant s.d. [iun. 1432 ?] Arm. XXXIX 6 189v." ;
        rgo:volume              "5" .

