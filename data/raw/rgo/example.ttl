        rgo:volume              "5" .

<https://example.org/rg/lemma/10508578>
        a                  rgo:RegestEntry ;
        rgo:hasSubEntry     <https://example.org/rg/sublemma/10508578-4> , <https://example.org/rg/sublemma/10508578-3> , <https://example.org/rg/sublemma/10508578-2> , <https://example.org/rg/sublemma/10508578-6> , <https://example.org/rg/sublemma/10508578-1> , <https://example.org/rg/sublemma/10508578-5> ;
        rgo:headText        "Theodericus de Moers aep. Colon. cuius mensa aepisc. p. guerras et alios sumptus pro fide catholica inter alia p. duos expeditiones contra Bohemos debitis irretita est et qui castra etc. impignorare debuit" ;
        rgo:mentionsPerson  <https://example.org/rg/person/10516275> , <https://example.org/rg/person/10517770> , <https://example.org/rg/person/10512650> , <https://example.org/rg/person/10518242> , <https://example.org/rg/person/10517697> , <https://example.org/rg/person/10516670> , <https://example.org/rg/person/10504258> , <https://example.org/rg/person/10517921> ;
